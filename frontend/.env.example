# Rename this file to ".env" for local overrides, or set this variable in
# your hosting provider's dashboard (Vercel/Netlify) when deploying.
#
# Local development: leave this unset — api.js falls back to
# http://127.0.0.1:8000 automatically.
#
# Production: set this to your deployed backend's URL.
VITE_API_URL=https://your-backend-url.onrender.com
